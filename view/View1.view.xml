                                                </viz:feeds>
                                            </viz:VizFrame>
                                        </VBox> -->

                                        <VBox width="50%">

    <!-- Select Control to change grouping -->
    <HBox justifyContent="End" class="sapUiSmallMarginBottom">
        <Select width="160px" change="onTimeChange" selectedKey="MONTH">
            <core:Item key="DAY" text="Day"/>
            <core:Item key="MONTH" text="Month"/>
            <core:Item key="QUARTER" text="Quarter"/>
            <core:Item key="YEAR" text="Year"/>
        </Select>
    </HBox>

    <!-- Column Chart -->
    <viz:VizFrame
        vizType="column"
        height="300px"
        width="100%"
        uiConfig="{applicationSet:'fiori'}"
        vizProperties="{
            title:{text:'Complaints Analysis'},
            plotArea:{
                dataLabel:{
                    visible:true
                }
            },
            categoryAxis:{
                title:{visible:true}
            },
            valueAxis:{
                title:{text:'Complaints'}
            }
        }">

        <!-- Dataset -->
        <viz:dataset>
            <viz.data:FlattenedDataset data="{salesModel>/data}">
                
                <!-- Dynamic X-Axis -->
                <viz.data:dimensions>
                    <viz.data:DimensionDefinition
                        name="Time"
                        value="{salesModel>time}"/>
                </viz.data:dimensions>

                <!-- Y-Axis -->
                <viz.data:measures>
                    <viz.data:MeasureDefinition
                        name="Complaints"
                        value="{salesModel>sales}"/>
                </viz.data:measures>

            </viz.data:FlattenedDataset>
        </viz:dataset>

        <!-- Chart Feeds -->
        <viz:feeds>
            <viz.feeds:FeedItem
                uid="valueAxis"
                type="Measure"
                values="Complaints"/>

            <viz.feeds:FeedItem
                uid="categoryAxis"
                type="Dimension"
                values="Time"/>
        </viz:feeds>

    </viz:VizFrame>

</VBox>
                                    </HBox>
                                </VBox>
                            </IconTabFilter>
                        </items>
                    </IconTabBar>
        </content>
    </Page>
</mvc:View>
