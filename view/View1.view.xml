                                            <viz:VizFrame
                                                vizType="column"
                                                height="350px"
                                                uiConfig="{applicationSet:'fiori'}"
                                                vizProperties="{
                                                    title:{text:'Monthly Complaints'},
                                                        plotArea:{
                                                            dataLabel:{
                                                                visible:true
                                                            }
                                                        }
                                                }">
                                                <viz:dataset>
                                                    <viz.data:FlattenedDataset data="{salesModel>/data}">
                                                        <viz.data:dimensions>
                                                            <viz.data:DimensionDefinition name="Month" value="{salesModel>month}"/>
                                                        </viz.data:dimensions>

                                                        <viz.data:measures>
                                                            <viz.data:MeasureDefinition name="Complaints" value="{salesModel>sales}"/>
                                                        </viz.data:measures>
                                                    </viz.data:FlattenedDataset>
                                                </viz:dataset>
                                                <viz:feeds>
                                                    <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Complaints"/>
