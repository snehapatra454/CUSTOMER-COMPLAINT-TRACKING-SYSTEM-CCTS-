<mvc:View
controllerName="project7.controller.View1"
xmlns:mvc="sap.ui.core.mvc"
xmlns="sap.m"
xmlns:core="sap.ui.core"
xmlns:smartTable="sap.ui.comp.smarttable"
xmlns:table="sap.ui.table"
xmlns:viz="sap.viz.ui5.controls"
xmlns:viz.data="sap.viz.ui5.data"
xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

<Page title="Complaint Management" enableScrolling="false">
    <content>
        <IconTabBar>
            <items>
                <IconTabFilter text="Complaints Table" icon="sap-icon://table-view">
                    <VBox width="100%" class="sapUiSmallMargin">
                        <Toolbar design="Transparent">
                            <Title text="Complaints" level="H2"/>
                            <ToolbarSpacer/>
                            <Button text="Create Complaint" icon="sap-icon://add" type="Emphasized" press="onCreate"/>
                            <SearchField width="300px" placeholder="Search Complaint / Customer" search="onSearch" liveChange="onSearch"/>
                            <Select width="160px" change="onStatusFilter">
                                <core:Item key="ALL" text="All"/>
                                <core:Item key="OPEN" text="Open"/>
                                <core:Item key="IN_PROGRESS" text="In Progress"/>
                                <core:Item key="RESOLVED" text="Resolved"/>
                            </Select>
                            <DatePicker width="180px" change="onDateFilter" placeholder="Created Date"/>
                        </Toolbar>
                        <table:Table id="complaintTable" rows="{/ZC_COMPLAINT}" selectionMode="None" rowSelectionChange="onRowSelect">
                            <table:columns>
                                <table:Column sortProperty="ComplaintNo">
                                    <Label text="Complaint ID"/>
                                    <table:template>
                                        <Link text="{ComplaintNo}" press="onRowSelect"/>
                                    </table:template>
                                </table:Column>
                                <table:Column>
                                    <Label text="Customer ID"/>
                                    <table:template>
                                        <Text text="{CustomerId}"/>
                                    </table:template>
                                </table:Column>
                                <table:Column>
                                    <Label text="Description"/>
                                    <table:template>
                                        <Text text="{ComplaintDesc}" wrapping="true"/>
                                    </table:template>
                                </table:Column>
                                <table:Column>
                                    <Label text="Status"/>
                                    <table:template>
                                        <ObjectStatus text="{Status}"
                                                    inverted="true"
                                                    state="{
                                                    path:'Status',
                                                    formatter:'.formatter.statusColor'
                                                }"/>
                                    </table:template>
                                </table:Column>
                                <table:Column>
                                    <Label text="Created Date"/>
                                    <table:template>
                                        <Text text="{CreatedDate}"/>
                                    </table:template>
                                </table:Column>
                            </table:columns>
                        </table:Table>
                        </VBox>
                            </IconTabFilter>
                                <IconTabFilter text="Analysis" icon="sap-icon://business-objects-experience">
                                <VBox class="sapUiLargeMargin">
                                    <HBox width="100%" justifyContent="Center" alignItems="Center">
                                        <VBox width="50%" alignItems="Stretch">
                                            <viz:VizFrame vizType="donut" width="90%" height="350px" uiConfig="{applicationSet:'fiori'}"
                                                vizProperties="{
                                                    title:{text:'Complaint Status'},
                                                    legend:{visible:true},
                                                    plotArea:{
                                                        dataLabel:{
                                                            visible:true,
                                                            type:'labelAndPercentage',
                                                            position:'inside'
                                                        },
                                                        innerRadius:'40%'
                                                    }
                                                }">
                                                <viz:dataset>
                                                    <viz.data:FlattenedDataset data="{donutModel>/data}">
                                                        <viz.data:dimensions>
                                                            <viz.data:DimensionDefinition name="Status" value="{donutModel>type}"/>
                                                        </viz.data:dimensions>
                                                        <viz.data:measures>
                                                            <viz.data:MeasureDefinition name="Complaints" value="{donutModel>value}"/>
                                                        </viz.data:measures>
                                                    </viz.data:FlattenedDataset>
                                                </viz:dataset>
                                                <viz:feeds>
                                                    <viz.feeds:FeedItem uid="size" type="Measure" values="Complaints"/>
                                                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Status"/>
                                                </viz:feeds>
                                            </viz:VizFrame>
                                        </VBox>
