<mvc:View
    controllerName="project7.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

<Page title="Complaint Details">
    <content>
        <Panel headerText="Complaint Details" class="sapUiMediumMarginTop"> 
            <VBox class="sapUiSmallMargin"> 
                <HBox class="sapUiSmallMarginBottom"> 
                    <Label text="Complaint ID" width="150px"/> 
                    <Input id="idComplaintID1" width="250px" value="{ComplaintNo}" editable="false"/> 
                </HBox> 

                <HBox class="sapUiSmallMarginBottom"> 
                    <Label text="Customer ID" width="150px"/> 
                    <Input id="idCustomerID1" width="250px" value="{CustomerId}" editable="false"/> 
                </HBox> 

                <HBox class="sapUiSmallMarginBottom"> 
                    <Label text="Description" width="150px"/> 
                    <Input id="idDescription1" width="400px" value="{ComplaintDesc}" editable="false"/> 
                </HBox> 

                <HBox> 
                    <Label text="Status" width="150px"/> 
                    <Select id="idStatus1" width="200px" selectedKey="{Status}"> 
                        <core:Item key="OPEN" text="OPEN"/> 
                        <core:Item key="IN_PROGRESS" text="IN_PROGRESS"/> 
                        <core:Item key="RESOLVED" text="RESOLVED"/> 
                    </Select> 
                </HBox> 
                <HBox> 
                    <Label text="Resolution Note" width="150px"/> 
                    <Input id="idResolutionNote" value="{ResolutionNote}" required="true"/> 
                </HBox>
                <Toolbar>
                    <ToolbarSpacer/>
                    <Button text="Update Status" icon="sap-icon://edit" press="onUpdateStatus" class="sapUiTinyMarginEnd"/> 
                    <Button
        text="Activate"
        icon="sap-icon://accept"
        type="Accept"
        press="onActivateDraft"
        class="sapUiTinyMarginEnd"/>
                    <Button text="Delete Complaint" icon="sap-icon://delete" type="Reject" press="onDelete"/> 
                </Toolbar> 
            </VBox> 
        </Panel> 
    </content>
</Page>
</mvc:View>